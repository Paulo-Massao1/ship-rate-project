rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /usuarios/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /navios/{shipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;

      match /avaliacoes/{ratingId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.auth.uid == request.resource.data.usuarioId;
        allow update, delete: if isSignedIn()
                              && resource.data.usuarioId == request.auth.uid;
      }
    }

    match /locais/{locationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;

      match /registros/{recordId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.auth.uid == request.resource.data.pilotId;
        allow update, delete: if isSignedIn()
                              && resource.data.pilotId == request.auth.uid;
      }
    }

    match /authorized_emails/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /otp_codes/{docId} {
      allow read, write: if false;
    }

    match /sugestoes/{docId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /{path=**}/registros/{recordId} {
      allow read: if isSignedIn();
    }
  }
}
