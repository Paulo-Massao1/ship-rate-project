rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isRestrictedModuleUser() {
      return isSignedIn()
             && (request.auth.uid == 'vvmd4t7NHgYEiRbE3aPPcyGscdq1'
                 || (request.auth.token.email != null
                     && (request.auth.token.email == 'plantao@nortepilot.com.br'
                         || request.auth.token.email == 'operacional@adjservicos.com.br'
                         || request.auth.token.email.matches('.*@cspam\\.com\\.br$'))));
    }

    function canAccessRestrictedModules() {
      return isSignedIn() && !isRestrictedModuleUser();
    }

    match /usuarios/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }

    match /pilotStats/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /navios/{shipId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;

      match /avaliacoes/{ratingId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
                      && request.auth.uid == request.resource.data.usuarioId;
        allow update, delete: if isSignedIn()
                              && resource.data.usuarioId == request.auth.uid;

        match /likes/{likeId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() && request.auth.uid == likeId;
          allow delete: if isSignedIn() && request.auth.uid == likeId;
        }
      }
    }

    match /locais/{locationId} {
      allow read: if canAccessRestrictedModules();
      allow create: if canAccessRestrictedModules();
      allow update: if false;
      allow delete: if canAccessRestrictedModules()
                    && resource.data.createdBy == request.auth.uid;

      match /registros/{recordId} {
        allow read: if canAccessRestrictedModules();
        allow create: if canAccessRestrictedModules()
                      && request.auth.uid == request.resource.data.pilotId;
        allow update, delete: if canAccessRestrictedModules()
                              && resource.data.pilotId == request.auth.uid;

        match /likes/{likeId} {
          allow read: if canAccessRestrictedModules();
          allow create: if canAccessRestrictedModules()
                        && request.auth.uid == likeId;
          allow delete: if canAccessRestrictedModules()
                        && request.auth.uid == likeId;
        }
      }
    }

    match /authorized_emails/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /otp_codes/{docId} {
      allow read, write: if false;
    }

    match /sugestoes/{docId} {
      allow read: if false;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /stats/{docId} {
      allow read: if isSignedIn()
                  && (docId != 'depthRecords' || canAccessRestrictedModules());
      allow write: if false;
    }

    match /cruzamentos/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.auth.uid == request.resource.data.pilotoId;
      allow update, delete: if isSignedIn()
                            && request.auth.uid == resource.data.pilotoId;
    }

    match /{path=**}/registros/{recordId} {
      allow read: if canAccessRestrictedModules();
    }
  }
}
